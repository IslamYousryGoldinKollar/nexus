{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "description": "Nexus — AI Chief of Staff for GoldinKollar. Multi-channel context-aware agentic system.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0 || >=22.0.0 || >=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @nexus/db db:generate",
    "db:migrate": "pnpm --filter @nexus/db db:migrate",
    "db:studio": "pnpm --filter @nexus/db db:studio",
    "db:push": "pnpm --filter @nexus/db db:push"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^20.17.6",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  }
}
