{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter=@nexus/web... build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/process-pending",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/auto-reason",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/sync-inngest",
      "schedule": "*/30 * * * *"
    }
  ]
}
