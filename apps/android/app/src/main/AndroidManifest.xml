<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network for API + FCM -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera for QR code scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Notifications (Android 13+ requires runtime grant) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Phase 8 — call-recording observer.
         No storage permissions needed: the user picks the recordings
         folder via Storage Access Framework (OpenDocumentTree) and we
         hold a persisted URI grant. READ_MEDIA_AUDIO is kept as a
         fallback for the legacy FileObserver path on older builds. -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground service for the recording observer -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Optional Wave-B fallback (mic-only recording). Uncomment if needed.
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    -->

    <application
        android:name=".NexusApplication"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nexus"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FCM message receiver. -->
        <service
            android:name=".push.NexusFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Call-recording observer service (Phase 8). Started from
             ApprovalsScreen once user grants storage perm. -->
        <service
            android:name=".recording.RecordingObserverService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
