<?xml version="1.0" encoding="utf-8"?>
<!-- Block backup of all app data — we store the device API key in
     EncryptedSharedPreferences and never want it leaving the device. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
