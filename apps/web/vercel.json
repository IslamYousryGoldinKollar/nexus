{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@nexus/web",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "ignoreCommand": "cd ../.. && npx turbo-ignore @nexus/web",
  "regions": ["fra1"],
  "functions": {
    "app/api/ingest/phone/route.ts": { "maxDuration": 60 },
    "app/api/ingest/teams/route.ts": { "maxDuration": 30 },
    "app/api/inngest/route.ts": { "maxDuration": 300 }
  }
}
