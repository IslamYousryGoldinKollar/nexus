{
  "manifest_version": 3,
  "name": "Nexus Meeting Recorder",
  "version": "0.2.0",
  "description": "Record MS Teams / Zoom / Meet meeting audio and ship it to Nexus for transcription + task extraction.",
  "permissions": ["storage", "activeTab", "alarms", "tabCapture", "offscreen"],
  "host_permissions": [
    "https://*.teams.microsoft.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.cloud.microsoft/*",
    "https://*.zoom.us/*",
    "https://meet.google.com/*",
    "https://nexus-beta-coral.vercel.app/*",
    "https://*.vercel.app/*",
    "https://nexus.goldinkollar.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Nexus Meeting Recorder",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
