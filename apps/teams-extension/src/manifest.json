{
  "manifest_version": 3,
  "name": "Nexus Teams Bridge",
  "version": "0.1.0",
  "description": "Forward MS Teams DMs to Nexus for context aggregation.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://teams.cloud.microsoft/*",
    "https://*.teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*",
        "https://*.teams.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Nexus Teams Bridge"
  },
  "icons": {}
}
