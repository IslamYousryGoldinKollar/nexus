# =============================================================================
# Nexus — Environment Variables
# Copy this to .env.local and fill in the values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
# Comma-separated list of superadmin emails that can sign in via magic link.
ADMIN_ALLOWED_EMAILS=islam@goldinkollar.com

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Pooled (pgbouncer, port 6543) — used by the app at runtime. Transaction mode.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
# Direct (port 5432) — used by Drizzle migrations + any DDL.
DATABASE_URL_UNPOOLED=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require

# Supabase project URL + API keys (for Phase 5 admin auth and storage).
SUPABASE_URL=https://PROJECT_REF.supabase.co
# Publishable (anon) key — safe to expose to the browser. Used by admin UI.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Bypasses RLS. Treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Cache / ephemeral (Upstash Redis)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Object storage (Cloudflare R2, S3-compatible)
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexus-attachments
R2_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# LLM (Anthropic Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MONTHLY_BUDGET_USD=200

# -----------------------------------------------------------------------------
# Transcription (Whisper + AssemblyAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=
WHISPER_MONTHLY_BUDGET_USD=100

# -----------------------------------------------------------------------------
# Inngest (durable workflows)
# -----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Optional: dev server URL override.
# INNGEST_BASE_URL=http://localhost:8288

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (Meta-hosted)
# -----------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Telegram (fallback HITL + client-side ingest bot)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_IDS=
TELEGRAM_ADMIN_CHAT_ID=

# -----------------------------------------------------------------------------
# Gmail (OAuth + Pub/Sub push)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_WATCHED_LABELS=INBOX
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_PUBSUB_VERIFICATION_TOKEN=

# -----------------------------------------------------------------------------
# Microsoft Teams (Chrome extension posts here; Graph API optional)
# -----------------------------------------------------------------------------
TEAMS_INGEST_API_KEY=
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Injaz (GoldinKollar project management)
# -----------------------------------------------------------------------------
INJAZ_API_BASE=https://injaz.goldinkollar.com/api
INJAZ_MCP_URL=https://injaz.goldinkollar.com/api/mcp/sse
INJAZ_API_KEY=

# -----------------------------------------------------------------------------
# Android phone recorder app (per-device API keys, comma-separated)
# -----------------------------------------------------------------------------
PHONE_INGEST_API_KEYS=
PHONE_INGEST_HMAC_SECRET=

# -----------------------------------------------------------------------------
# Push notifications (Firebase Cloud Messaging)
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Magic-link auth (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=nexus@goldinkollar.com
AUTH_SECRET=replace-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Mobile device pairing
# -----------------------------------------------------------------------------
# 32-byte base64 secret used to sign short-lived pairing tokens.
DEVICE_PAIRING_SECRET=replace-with-openssl-rand-base64-32
# HS256 secret for long-lived device JWTs.
DEVICE_JWT_SECRET=replace-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
AXIOM_TOKEN=
AXIOM_DATASET=nexus
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Feature flags / operational tunables
# -----------------------------------------------------------------------------
# Session silence timeout in minutes (default 120 per architect's recommendation).
SESSION_COOLDOWN_MIN=120
# Cron schedule for session sweep (default every 2h).
SESSION_SWEEP_CRON=0 */2 * * *
# Identity learning mode — route ALL non-exact matches through HITL for first 30 days.
IDENTITY_LEARNING_MODE=true
# Notification fallback delay in minutes (Telegram fires after this many minutes of no action).
NOTIFY_FALLBACK_PROPOSAL_MIN=30
NOTIFY_FALLBACK_PENDING_ID_MIN=10
NOTIFY_FALLBACK_INJAZ_FAIL_MIN=60
